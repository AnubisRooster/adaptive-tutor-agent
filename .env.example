# --- Ollama (server-side only; never exposed to LAN clients) ---
# Where the host machine reaches its local Ollama instance.
OLLAMA_HOST=http://127.0.0.1:11434

# Conversational tutor model. Must EXACTLY match a tag you've pulled with Ollama.
# gemma4:e4b-it-qat is QAT-optimized for fast on-device inference (great on Apple Silicon).
# Other options: gemma4 (larger/slower), llama3.2:3b, qwen2.5:7b, etc.
TUTOR_MODEL=gemma4:e4b-it-qat

# Embedding model used for RAG knowledge retrieval.
EMBED_MODEL=nomic-embed-text

# --- Server / network ---
# Bind to 0.0.0.0 so other computers on the LAN can reach the tutor.
HOST=0.0.0.0
PORT=3000

# Path to the SQLite database file (created automatically).
DATABASE_PATH=./data/tutor.db

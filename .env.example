# --- Ollama (server-side only; never exposed to LAN clients) ---
# Where the host machine reaches its local Ollama instance.
OLLAMA_HOST=http://127.0.0.1:11434

# Conversational tutor model. Must EXACTLY match a tag you've pulled with Ollama.
# gemma4:e4b-it-qat is QAT-optimized for fast on-device inference (great on Apple Silicon).
# Other options: gemma4 (larger/slower), llama3.2:3b, qwen2.5:7b, etc.
TUTOR_MODEL=gemma4:e4b-it-qat

# Embedding model used for RAG knowledge retrieval.
# Embeddings always use local Ollama regardless of each user's chat provider.
EMBED_MODEL=nomic-embed-text

# --- OpenRouter (optional cloud models) ---
# Users set their own API keys via the Model Settings picker in the learn UI.
# Keys are stored per-user in the local SQLite DB and are never sent to the browser.
#
# Optional: pre-set a server-wide default OpenRouter key (used if a user has
# no personal key but has selected openrouter as their provider — useful for
# shared family/classroom deployments where the host wants to pay centrally).
# Leave unset if you want each user to provide their own key.
# OPENROUTER_API_KEY=sk-or-...
#
# Optional: override the OpenRouter API base URL (useful for self-hosted proxies).
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Server / network ---
# Bind to 0.0.0.0 so other computers on the LAN can reach the tutor.
HOST=0.0.0.0
PORT=3000

# Path to the SQLite database file (created automatically).
DATABASE_PATH=./data/tutor.db

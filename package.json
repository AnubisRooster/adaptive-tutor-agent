{
  "name": "adaptive-tutor-agent",
  "version": "0.1.0",
  "private": true,
  "description": "A LAN-accessible, multi-user adaptive tutoring agent powered by a local Ollama model.",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "db:migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "setup": "npm run db:migrate && npm run seed",
    "bootstrap": "node scripts/setup.mjs",
    "launch": "node scripts/launch.mjs",
    "app:install": "node scripts/install-macos-app.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "tsx tests/e2e/run-e2e.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.38.3",
    "next": "^15.1.4",
    "ollama": "^0.5.12",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "unpdf": "^1.6.2",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
